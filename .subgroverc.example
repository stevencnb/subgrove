# subgrove configuration.
# Place this file at the superproject root as `.subgroverc` (no .example suffix).
# Sourced by `subgrove` at startup. subgrove refuses to run a repo-touching
# command unless this file exists — run `subgrove init` to generate it.

# WORKTREES_DIR: folder (relative to the superproject root) holding one
# subdirectory per feature worktree. Must be gitignored — subgrove refuses to
# run otherwise. Default ".worktree".
WORKTREES_DIR=".worktree"

# BUILD_CHAIN: ordered submodule paths to build during `new`. Each module is
# built by running BUILD_CMD inside its directory. Empty = no auto-build.
BUILD_CHAIN=()

# BUILD_CMD: shell command run inside each BUILD_CHAIN module. Used only when
# BUILD_CHAIN is non-empty and `new` is invoked without `build=false`.
BUILD_CMD="./init.sh && ./build.sh"

# COPY_TO_NEW_WORKTREE: files or directories under the main worktree to copy
# into each new worktree (e.g. local-only editor settings, generated TLS
# certs). Items missing in the main worktree are silently skipped.
COPY_TO_NEW_WORKTREE=()

# BRANCH_PREFIX: feature branch prefix. e.g. "feat/" + name "foo" → "feat/foo".
# Include the trailing separator if you want one (typically "/").
BRANCH_PREFIX="feat/"
