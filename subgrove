#!/usr/bin/env bash
#
# subgrove - parallel feature worktrees for a git superproject with submodules.
#
# Each feature lives in its own parent worktree with isolated submodule git
# dirs; merges propagate across linked worktrees so every worktree's view of
# `main` stays consistent. Project-specific knobs (WORKTREES_DIR, BUILD_CHAIN,
# BRANCH_PREFIX, COPY_TO_NEW_WORKTREE, BUILD_CMD) live in .subgroverc at the
# superproject root; see .subgroverc.example. Design rationale: docs/design/.
#
# Usage:
#   subgrove init                          Guided setup: write .subgroverc, gitignore .worktree/.
#   subgrove new <name>                    Create .worktree/<name>/, branch
#                                            <prefix><name> in parent + every
#                                            submodule, run BUILD_CHAIN.
#   subgrove new <name> touch=<sm>,<sm>    Branch only the listed submodules.
#   subgrove new <name> touch=none         Parent-only branch; submodules detached.
#   subgrove new <name> build=false        Skip BUILD_CHAIN (run manually later).
#   subgrove merge <name>                  FF-merge <prefix><name> back to main in every
#                                            touched submodule + parent. Refuses if anything
#                                            is dirty or non-FF. Worktree is never removed —
#                                            use `remove` separately when you're done.
#   subgrove merge <name> push=true        Also push merged main branches to origin.
#   subgrove remove <name>                 Remove worktree (refuses if dirty; branches remain).
#   subgrove remove <name> -f              Discard uncommitted work and force-remove (force=true).
#   subgrove update <name>                 Fetch origin in main worktree, then FF each submodule's
#                                            main in <name>. Manual escape hatch when a peer worktree
#                                            needs to catch up without going through merge propagation.
#   subgrove status [--fetch]              Per-worktree branch, touched submodules, and local + origin/main
#                                            state. Read-only; --fetch refreshes origin/main first.
#   subgrove list                          Show worktrees and their feature branches.
#   subgrove help                          Show this help.
#   subgrove --version                     Print the version.

set -eo pipefail   # no -u: macOS bash 3.2 trips on empty-array expansion

VERSION="0.1.0"
# Default worktree folder (repo-relative); overridable via WORKTREES_DIR in
# .subgroverc. Holds one subdirectory per feature worktree, and must be
# gitignored — subgrove refuses to run otherwise (assert_worktrees_ignored).
WORKTREES_DIR=".worktree"
ROOT=""   # superproject root; discover_root sets this per-command (git toplevel)

# Defaults; overridden by the superproject's .subgroverc, which discover_root
# sources once the repo root is known. Each value is documented in
# .subgroverc.example.
BUILD_CHAIN=()
BUILD_CMD="./init.sh && ./build.sh"
COPY_TO_NEW_WORKTREE=()
BRANCH_PREFIX="feat/"

err() { echo "Error: $*" >&2; exit 1; }
info() { echo ">>> $*"; }

# Rollback support for cmd_new — wired via trap once a worktree dir has been
# materialised. Globals (not locals) so the EXIT-trap handler sees them no
# matter where in the call stack the failure originated.
ROLLBACK_WT=""
ROLLBACK_BR=""
ROLLBACK_BR_SHA=""
_rollback_new() {
    local rc=$?
    if [[ -n "$ROLLBACK_WT" ]]; then
        echo ">>> rolling back partial worktree at $ROLLBACK_WT" >&2
        rm -rf "$ROLLBACK_WT"
        git -C "$ROOT" worktree prune 2>/dev/null || true
        if [[ -n "$ROLLBACK_BR" ]]; then
            # Don't delete the branch if it advanced past where `git worktree
            # add` left it: an atypical build chain that committed onto the
            # parent feat branch before failing would otherwise lose that work.
            # The worktree dir is still removed; a retry of the same name then
            # errs on the existing branch rather than trampling the commits.
            local cur_sha
            cur_sha="$(git -C "$ROOT" rev-parse --verify --quiet "refs/heads/$ROLLBACK_BR" 2>/dev/null || true)"
            if [[ -n "$cur_sha" && "$cur_sha" != "$ROLLBACK_BR_SHA" ]]; then
                echo ">>> branch $ROLLBACK_BR advanced past its creation point; left in place (git branch -D $ROLLBACK_BR to discard)" >&2
            else
                git -C "$ROOT" branch -D "$ROLLBACK_BR" 2>/dev/null || true
            fi
        fi
    fi
    exit "$rc"
}

usage() {
    cat <<'EOF'
subgrove - parallel feature worktrees for a git superproject with submodules

  subgrove init                          Guided setup: write .subgroverc, gitignore .worktree/.
  subgrove new <name>                    Create .worktree/<name>/, branch <prefix><name> in
                                         parent + every submodule, then run BUILD_CHAIN.
  subgrove new <name> touch=<sm>,<sm>    Branch only the listed submodules.
  subgrove new <name> touch=none         Parent-only branch; submodules detached.
  subgrove new <name> build=false        Skip BUILD_CHAIN (run manually later).
  subgrove merge <name>                  FF-merge <prefix><name> to main in every touched
                                         submodule + parent. Refuses if dirty or non-FF.
  subgrove merge <name> push=true        Also push merged main branches to origin.
  subgrove remove <name>                 Remove worktree (refuses if dirty; branches remain).
  subgrove remove <name> -f              Discard uncommitted work and force-remove (force=true).
  subgrove update <name>                 Catch a peer worktree up to origin/main without merging.
  subgrove status [--fetch]              Per-worktree branch, touched submodules, local + remote state.
  subgrove list                          Show worktrees and their feature branches.
  subgrove help                          Show this help.
  subgrove --version                     Print the version.

See docs/design/ for design rationale, docs/usage.md for the long-form reference.
EOF
}

# ---- Validation ---------------------------------------------------------

validate_name() {
    local name="${1:-}"
    [[ -z "$name" ]] && err "feature name required"
    [[ "$name" =~ ^[a-zA-Z0-9._-]+$ ]] || err "name must match [a-zA-Z0-9._-]+, got '$name'"
    [[ "$name" =~ ^[.-] ]] && err "name must not start with '.' or '-'"
    return 0
}

assert_main_worktree() {
    local git_dir git_common
    git_dir="$(git rev-parse --git-dir 2>/dev/null)" || err "not in a git repo"
    git_common="$(git rev-parse --git-common-dir 2>/dev/null)"
    git_dir="$(cd "$git_dir" && pwd)"
    git_common="$(cd "$git_common" && pwd)"
    [[ "$git_dir" == "$git_common" ]] || err "run from the main worktree (currently in a linked worktree)"
}

# Discover the superproject root from the current directory and load its
# config. Must run before any command touches the repo, and refuses inside a
# linked worktree. Sets the global ROOT (git toplevel) and sources
# $ROOT/.subgroverc over the defaults — so a script on PATH (Homebrew)
# operates on whatever superproject the user is standing in, not on wherever
# the script itself happens to live.
#
# A missing .subgroverc is fatal for every repo-touching command: the repo
# hasn't been set up for subgrove, so we stop and point at `init` rather than
# silently operating on built-in defaults. Only `init` — which *writes* the
# config — opts out, by passing --allow-missing-config.
discover_root() {
    local allow_missing_config=false
    [[ "${1:-}" == "--allow-missing-config" ]] && allow_missing_config=true
    assert_main_worktree
    ROOT="$(git rev-parse --show-toplevel)" || err "could not determine superproject root"
    if [[ -f "$ROOT/.subgroverc" ]]; then
        # shellcheck source=/dev/null
        . "$ROOT/.subgroverc"
    elif [[ "$allow_missing_config" == "false" ]]; then
        err "no .subgroverc found at $ROOT
    This repo isn't set up for subgrove yet. Run:
        subgrove init"
    fi
}

assert_worktrees_ignored() {
    git check-ignore -q "$WORKTREES_DIR" 2>/dev/null || err "$WORKTREES_DIR/ is not gitignored.
    Add it first:
        echo '$WORKTREES_DIR/' >> .gitignore && git add .gitignore && git commit -m 'chore: ignore worktrees'"
}

# is_clean DIR  -> 0 if working tree + index are clean, 1 otherwise (untracked allowed)
is_clean() {
    git -C "$1" diff --quiet 2>/dev/null && git -C "$1" diff --cached --quiet 2>/dev/null
}

require_clean() {
    local label="$1" dir="$2"
    is_clean "$dir" || err "$label has uncommitted changes — clear it and re-run.
        cd $dir
        git status            # see what's changed
        # Avoid 'git stash' when a 'M <submodule>' line is present — the stash
        # captures an old SHA delta that becomes a revert after merge advances
        # HEAD past it."
}

# ---- Argument parsing ---------------------------------------------------

# parse_kv KEY DEFAULT ARGS...  -> echoes value found in ARGS, else DEFAULT
parse_kv() {
    local key="$1" default="$2"; shift 2
    local arg
    for arg in "$@"; do
        if [[ "$arg" == "$key="* ]]; then
            echo "${arg#*=}"
            return 0
        fi
    done
    echo "$default"
}

# ---- Submodule helpers --------------------------------------------------

list_all_submodules() {
    git config --file "$ROOT/.gitmodules" --get-regexp 'submodule\..*\.path' | awk '{print $2}'
}

# resolve_touch_list VALUE  -> prints submodule paths, one per line
resolve_touch_list() {
    local value="$1"
    case "$value" in
        all)  list_all_submodules ;;
        none) ;;
        *)    tr ',' '\n' <<< "$value" | sed '/^$/d' ;;
    esac
}

# ---- Subcommands --------------------------------------------------------

cmd_new() {
    local name="${1:-}"
    validate_name "$name"
    shift || true

    local touch_arg build_arg
    touch_arg="$(parse_kv touch all "$@")"
    build_arg="$(parse_kv build true "$@")"

    discover_root
    cd "$ROOT"
    assert_worktrees_ignored

    local branch="${BRANCH_PREFIX}$name"
    local wt_path="$ROOT/$WORKTREES_DIR/$name"
    local base="main"
    local item sm sm_path module
    local touch_list=()

    [[ -e "$wt_path" ]] && err "$wt_path already exists"
    if git rev-parse --verify --quiet "refs/heads/$branch" >/dev/null; then
        err "branch '$branch' already exists in parent repo"
    fi

    # Pick the freshest available base. Without this, a worktree silently
    # branches off whatever local refs happened to be when the user last
    # pulled — exactly the staleness mode we just fixed in cmd_merge.
    info "Fetching origin/main"
    git fetch --quiet origin main || echo "    warn: parent fetch failed; continuing with local refs"
    if git rev-parse --verify --quiet refs/remotes/origin/main >/dev/null; then
        base="origin/main"
    fi

    info "Creating worktree at $wt_path on branch $branch (base: $base)"
    git worktree add "$wt_path" -b "$branch" "$base"

    # Arm rollback: from here onwards, any non-zero exit (including err / set -e
    # / Ctrl-C) tears down the half-built worktree so a retry of the same name
    # doesn't trip on residue. Disarmed at end of cmd_new on success.
    ROLLBACK_WT="$wt_path"
    ROLLBACK_BR="$branch"
    ROLLBACK_BR_SHA="$(git -C "$ROOT" rev-parse --verify --quiet "refs/heads/$branch" 2>/dev/null || true)"
    trap _rollback_new EXIT INT TERM

    for item in "${COPY_TO_NEW_WORKTREE[@]}"; do
        if [[ -e "$ROOT/$item" ]]; then
            info "Copying $item (untracked)"
            cp -a "$ROOT/$item" "$wt_path/"
        fi
    done

    # Submodule git dirs are isolated per parent worktree, but we can avoid
    # re-cloning every submodule by passing --reference to the underlying
    # clone. This sets objects/info/alternates in the new submodule git dir
    # to borrow from main worktree's, saving bandwidth + disk.
    info "Initialising submodules (sharing objects with main worktree where possible)"
    while IFS= read -r sm; do
        if [[ -d "$ROOT/.git/modules/$sm" ]]; then
            ( cd "$wt_path" && git submodule update --init --reference "$ROOT/.git/modules/$sm" -- "$sm" ) \
                || err "submodule init failed for $sm"
        else
            ( cd "$wt_path" && git submodule update --init -- "$sm" ) \
                || err "submodule init failed for $sm"
        fi
    done < <(list_all_submodules)

    while IFS= read -r sm; do
        [[ -n "$sm" ]] && touch_list+=("$sm")
    done < <(resolve_touch_list "$touch_arg")

    if [[ ${#touch_list[@]} -gt 0 ]]; then
        info "Branching ${#touch_list[@]} submodule(s) to $branch"
        for sm in "${touch_list[@]}"; do
            sm_path="$wt_path/$sm"
            [[ -d "$sm_path" ]] || err "$sm: no such submodule path under $wt_path"
            # Submodule git dirs are freshly created by `git submodule update --init`
            # under .git/worktrees/<name>/modules/<sm>/, so refs are empty and a
            # collision here is a genuine error rather than a recoverable skip.
            ( cd "$sm_path" && git checkout -b "$branch" ) \
                || err "$sm: failed to create branch '$branch'"
        done
    else
        info "Submodule branching skipped (touch=none)"
    fi

    if [[ ${#BUILD_CHAIN[@]} -eq 0 ]]; then
        info "No BUILD_CHAIN configured — skipping auto-build"
    elif [[ "$build_arg" == "true" ]]; then
        info "Running build chain (cold builds are slow)"
        for module in "${BUILD_CHAIN[@]}"; do
            info "  build: $module"
            ( cd "$wt_path/$module" && eval "$BUILD_CMD" )
        done
    else
        info "Build chain skipped (build=false). Run manually:"
        for module in "${BUILD_CHAIN[@]}"; do
            echo "    ( cd $wt_path/$module && $BUILD_CMD )"
        done
    fi

    # Disarm rollback — cmd_new completed successfully.
    ROLLBACK_WT=""
    ROLLBACK_BR=""
    ROLLBACK_BR_SHA=""
    trap - EXIT INT TERM

    cat <<EOF

Worktree ready: $wt_path
Branch:         $branch
EOF
}

cmd_remove() {
    local name="${1:-}"
    validate_name "$name"
    shift || true

    # Allow -f / --force as shorthand for force=true.
    local args=() arg
    for arg in "$@"; do
        case "$arg" in
            -f|--force) args+=("force=true") ;;
            *)          args+=("$arg") ;;
        esac
    done
    set -- "${args[@]}"

    local force_arg
    force_arg="$(parse_kv force false "$@")"

    discover_root
    cd "$ROOT"

    local wt_path="$ROOT/$WORKTREES_DIR/$name"
    [[ -d "$wt_path" ]] || err "$wt_path does not exist (or is not a directory)"

    if [[ "$force_arg" != "true" ]]; then
        info "Checking for uncommitted changes (force=true to bypass)"
        require_clean "feature worktree (parent)" "$wt_path"
        # Check every initialised submodule, not just ones with the feature
        # branch — un-branched but edited submodules would otherwise be wiped
        # by the rm -rf below without warning.
        local sm
        while IFS= read -r sm; do
            [[ -e "$wt_path/$sm/.git" ]] || continue
            require_clean "submodule '$sm' in feature worktree" "$wt_path/$sm"
        done < <(list_all_submodules)
    fi

    # Preserve any submodule feat branches by fetching them into main
    # worktree's submodule git dirs BEFORE prune wipes the per-worktree
    # submodule storage. Per lifecycle.md, "submodule branches are retained"
    # — without this preservation, `git worktree prune` (below) cleans
    # .git/worktrees/<name>/modules/<sm>/ and any refs there go with it.
    # After remove, the user can access these preserved branches from main
    # worktree's submodule (e.g. `git -C <super>/<sm> log feat/<name>`).
    local branch_to_preserve="${BRANCH_PREFIX}$name"
    local sm sm_path main_sm_path
    local preserved=0
    while IFS= read -r sm; do
        sm_path="$wt_path/$sm"
        [[ -e "$sm_path/.git" ]] || continue
        git -C "$sm_path" rev-parse --verify --quiet "refs/heads/$branch_to_preserve" >/dev/null 2>&1 \
            || continue
        main_sm_path="$ROOT/$sm"
        [[ -d "$ROOT/.git/modules/$sm" ]] || continue
        if git -C "$main_sm_path" fetch --quiet "$sm_path" \
                "+refs/heads/$branch_to_preserve:refs/heads/$branch_to_preserve" 2>/dev/null; then
            preserved=$((preserved + 1))
        else
            # Abort before the rm -rf below rather than warn-and-continue: the
            # feat branch's commits live only in the worktree's submodule git
            # dir until this fetch copies them out, so proceeding would destroy
            # them. -f bypasses the cleanliness gate, never this preservation gate.
            err "$sm: failed to preserve refs/heads/$branch_to_preserve into main worktree — aborting before removal so its commits aren't lost.
        The feature branch still lives in $sm_path. Recover it, then re-run remove:
            git -C $main_sm_path fetch $sm_path '+refs/heads/$branch_to_preserve:refs/heads/$branch_to_preserve'"
        fi
    done < <(list_all_submodules)
    if [[ "$preserved" -gt 0 ]]; then
        info "Preserved $preserved submodule feat branch(es) into main worktree's submodule git dirs"
    fi

    # `git worktree remove` refuses on worktrees containing submodules (git 2.40+;
    # --force does not bypass it). The cleanliness gate above is our equivalent
    # safety check; the actual removal is a direct rm + prune. `git worktree
    # prune` recursively cleans .git/worktrees/<name>/ including the submodule
    # git dirs nested under it (modules/<sm>/) — which is why we preserved the
    # feat branches above first.
    info "Removing worktree at $wt_path (branches retained)"
    rm -rf "$wt_path"
    git worktree prune
}

cmd_merge() {
    local name="${1:-}"
    validate_name "$name"
    shift || true

    local push_arg
    push_arg="$(parse_kv push false "$@")"

    discover_root
    cd "$ROOT"

    local branch="${BRANCH_PREFIX}$name"
    local wt_path="$ROOT/$WORKTREES_DIR/$name"
    [[ -d "$wt_path" ]] || err "$wt_path does not exist"
    git rev-parse --verify --quiet "refs/heads/$branch" >/dev/null \
        || err "parent branch '$branch' not found"

    # Discover touched submodules: those with a local feature branch.
    info "Discovering touched submodules"
    local touched=() sm sm_path
    while IFS= read -r sm; do
        sm_path="$wt_path/$sm"
        [[ -e "$sm_path/.git" ]] || continue
        if git -C "$sm_path" rev-parse --verify --quiet "refs/heads/$branch" >/dev/null; then
            touched+=("$sm")
        fi
    done < <(list_all_submodules)
    if [[ ${#touched[@]} -gt 0 ]]; then
        echo "    touched: ${touched[*]}"
    else
        echo "    touched: (none)"
    fi

    # --- Validation: no uncommitted changes in source (feature) or dst (main) ---
    # Done broadly across every touched submodule, even ones with no commits —
    # uncommitted work in a "no-op" submodule is still work the user could lose.
    info "Checking for uncommitted changes (source + dst)"
    require_clean "main worktree (parent, dst)"    "$ROOT"
    require_clean "feature worktree (parent, src)" "$wt_path"
    for sm in "${touched[@]}"; do
        require_clean "main submodule '$sm' (dst)"    "$ROOT/$sm"
        require_clean "feature submodule '$sm' (src)" "$wt_path/$sm"
    done

    # --- Filter: feat tip vs MAIN-WORKTREE's main (each parent worktree has
    # an independent submodule git dir; the "destination" main lives in main
    # worktree's submodule, not the linked one).
    info "Filtering to modules with new commits"
    local needs_merge=() skipped=()
    local feat_sha main_sha linked_sm_path main_sm_path
    for sm in "${touched[@]}"; do
        linked_sm_path="$wt_path/$sm"
        main_sm_path="$ROOT/$sm"
        feat_sha="$(git -C "$linked_sm_path" rev-parse "refs/heads/$branch")"
        main_sha=""
        if git -C "$main_sm_path" rev-parse --verify --quiet refs/heads/main >/dev/null 2>&1; then
            main_sha="$(git -C "$main_sm_path" rev-parse refs/heads/main)"
        fi
        if [[ "$feat_sha" == "$main_sha" ]]; then
            skipped+=("$sm")
        else
            needs_merge+=("$sm")
        fi
    done
    local parent_needs_merge=true
    if [[ "$(git rev-parse refs/heads/main)" == "$(git rev-parse "refs/heads/$branch")" ]]; then
        parent_needs_merge=false
    fi
    [[ ${#skipped[@]} -gt 0 ]] && echo "    skip (no commits): ${skipped[*]}"
    if [[ ${#needs_merge[@]} -eq 0 ]] && [[ "$parent_needs_merge" == "false" ]]; then
        info "Nothing to merge (everything already at feat tip)"
    else
        echo "    will merge submodules: ${needs_merge[*]:-(none)}"
        echo "    will merge parent:     $parent_needs_merge"
    fi

    # --- Phase 1: validation pass — fetch feat objects and run all FF checks
    # before any main is moved. Without this split, a non-FF on submodule N+1
    # would leave the first N submodules already moved (half-state).
    if [[ ${#needs_merge[@]} -gt 0 ]]; then
        info "Validating fast-forward feasibility"
        for sm in "${needs_merge[@]}"; do
            linked_sm_path="$wt_path/$sm"
            main_sm_path="$ROOT/$sm"
            [[ -e "$main_sm_path/.git" ]] \
                || err "submodule '$sm' is not initialized in main worktree at $main_sm_path"

            # Submodule git dirs are isolated per parent worktree — ship the
            # feat-branch objects + ref into main worktree's submodule git
            # dir. Creates refs/heads/<branch> there but does NOT move main.
            # --quiet hides "From <path>" progress noise; real errors still
            # reach stderr so the err line below is accompanied by git's own
            # reason rather than appearing as a bare wrapper message.
            git -C "$main_sm_path" fetch --quiet "$linked_sm_path" \
                "+refs/heads/$branch:refs/heads/$branch" \
                || err "$sm: failed to fetch $branch from $linked_sm_path"

            if git -C "$main_sm_path" rev-parse --verify --quiet refs/heads/main >/dev/null 2>&1; then
                git -C "$main_sm_path" merge-base --is-ancestor refs/heads/main "refs/heads/$branch" 2>/dev/null \
                    || err "submodule '$sm' main (main worktree) is not ancestor of $branch (non-FF).
        Rebase the feature branch first:
            ( cd $linked_sm_path && git fetch $main_sm_path main && git rebase FETCH_HEAD )"
            fi
        done
    fi
    if [[ "$parent_needs_merge" == "true" ]]; then
        git merge-base --is-ancestor refs/heads/main "refs/heads/$branch" 2>/dev/null \
            || err "parent main is not ancestor of $branch (non-FF).
        Rebase first:  git rebase main $branch"
    fi

    # --- Phase 2: mutation pass — all checks passed, now move refs.
    if [[ ${#needs_merge[@]} -gt 0 ]]; then
        info "Moving main forward in main worktree's submodules"
        for sm in "${needs_merge[@]}"; do
            linked_sm_path="$wt_path/$sm"
            main_sm_path="$ROOT/$sm"
            feat_sha="$(git -C "$linked_sm_path" rev-parse "refs/heads/$branch")"
            echo "    $sm: main → ${feat_sha:0:12}"
            # checkout -B reattaches HEAD → refs/heads/main, force-moves it to
            # feat_sha, and updates the working tree atomically. Cleanliness
            # was already gated by require_clean above.
            git -C "$main_sm_path" checkout -B main "$feat_sha" --quiet \
                || err "$sm: failed to FF main worktree's submodule to ${feat_sha:0:12}"
        done
    fi

    if [[ "$parent_needs_merge" == "true" ]]; then
        info "Fast-forwarding parent main"
        git merge --ff-only "$branch"
    fi

    # --- Propagate new submodule main to peer worktrees ---
    # Submodule git dirs are isolated per parent worktree, so peer worktrees
    # have their own refs/heads/main that would otherwise lag forever. Parent
    # refs are shared, so no parent-side propagation is needed.
    if [[ ${#needs_merge[@]} -gt 0 ]] && [[ -d "$ROOT/$WORKTREES_DIR" ]]; then
        local peer_wt peer_name peer_sm peer_count=0 peer_skipped=0
        local propagated=false
        for peer_wt in "$ROOT/$WORKTREES_DIR"/*; do
            [[ -d "$peer_wt" ]] || continue
            [[ "$peer_wt" == "$wt_path" ]] && continue
            peer_name="$(basename "$peer_wt")"
            for sm in "${needs_merge[@]}"; do
                peer_sm="$peer_wt/$sm"
                [[ -e "$peer_sm/.git" ]] || continue
                if [[ "$propagated" == "false" ]]; then
                    info "Propagating new main to peer worktrees"
                    propagated=true
                fi
                # No `+`: refuse non-FF rather than clobber a peer's diverged main.
                # Two distinct failure modes — distinguish via HEAD inspection
                # so the warning points at the actual cause.
                if git -C "$peer_sm" fetch "$ROOT/$sm" \
                       refs/heads/main:refs/heads/main 2>/dev/null; then
                    peer_count=$((peer_count + 1))
                else
                    local peer_head
                    peer_head="$(git -C "$peer_sm" symbolic-ref --quiet HEAD 2>/dev/null || true)"
                    if [[ "$peer_head" == "refs/heads/main" ]]; then
                        echo "    warn: $peer_name/$sm has main checked out — propagation refused (run 'git checkout <feat>' there, then re-merge)"
                    else
                        echo "    warn: $peer_name/$sm main has diverged from main worktree's main — left as-is"
                    fi
                    peer_skipped=$((peer_skipped + 1))
                    continue
                fi
                # If we're about to push, mirror peer's origin/main too so the
                # peer's remote-tracking ref doesn't lag the actual origin.
                if [[ "$push_arg" == "true" ]]; then
                    git -C "$peer_sm" fetch "$ROOT/$sm" \
                        "+refs/heads/main:refs/remotes/origin/main" 2>/dev/null || true
                fi
            done
        done
        if [[ "$propagated" == "true" ]]; then
            echo "    propagated to $peer_count peer module(s); $peer_skipped skipped"
        fi
    fi

    if [[ "$push_arg" == "true" ]]; then
        if [[ ${#needs_merge[@]} -eq 0 ]] && [[ "$parent_needs_merge" == "false" ]]; then
            info "Push skipped (nothing was merged)"
        else
            info "Pushing updated main branches to origin"
            for sm in "${needs_merge[@]}"; do
                echo "    pushing $sm main"
                git -C "$ROOT/$sm" push origin main
            done
            if [[ "$parent_needs_merge" == "true" ]]; then
                echo "    pushing parent main"
                git push origin main
            fi
        fi
    else
        info "Push skipped (push=true to enable)"
    fi

    info "Worktree retained at $wt_path (use 'remove' separately when ready)"

    cat <<EOF

Merge complete.
  Branch:             $branch
  Submodules merged:  ${needs_merge[*]:-(none)}
  Submodules skipped: ${skipped[*]:-(none)}
  Parent merged:      $parent_needs_merge
  Pushed:             $push_arg
EOF
}

cmd_update() {
    local name="${1:-}"
    validate_name "$name"

    discover_root
    cd "$ROOT"

    local wt_path="$ROOT/$WORKTREES_DIR/$name"
    [[ -d "$wt_path" ]] || err "$wt_path does not exist"

    info "Fetching origin/main in main worktree (parent + submodules)"
    git fetch --quiet origin main \
        || echo "    warn: parent fetch failed; continuing with local refs"
    local sm
    while IFS= read -r sm; do
        [[ -e "$ROOT/$sm/.git" ]] || continue
        git -C "$ROOT/$sm" fetch --quiet origin main \
            || echo "    warn: $sm fetch failed; continuing with local refs"
    done < <(list_all_submodules)

    info "FF-updating peer worktree '$name' submodule mains from origin/main"
    local peer_sm peer_head updated=0 skipped=0 main_sm_path
    local sync_ref="refs/heads/_update_sync"
    while IFS= read -r sm; do
        peer_sm="$wt_path/$sm"
        [[ -e "$peer_sm/.git" ]] || continue
        main_sm_path="$ROOT/$sm"
        [[ -d "$ROOT/.git/modules/$sm" ]] || continue

        # Source of truth is refs/remotes/origin/main (what we just fetched),
        # NOT refs/heads/main (which the origin fetch never advanced). Local-
        # path `git fetch` uses upload-pack and upload-pack only advertises
        # refs/heads/* and refs/tags/*, so we stage origin/main under a
        # transient head ref for the duration of the fetch.
        if ! git -C "$main_sm_path" rev-parse --verify --quiet refs/remotes/origin/main >/dev/null; then
            echo "    warn: $sm — no refs/remotes/origin/main in main worktree; skipped"
            skipped=$((skipped + 1))
            continue
        fi
        # Pre-clean defensively in case a prior interrupted run left it — but
        # never clobber a user's real branch that happens to be named
        # _update_sync. A stale sentinel was written pointing at origin/main, so
        # it is reachable from the current origin/main; a user branch carrying
        # independent work is not.
        if git -C "$main_sm_path" rev-parse --verify --quiet "$sync_ref" >/dev/null 2>&1; then
            if git -C "$main_sm_path" merge-base --is-ancestor "$sync_ref" refs/remotes/origin/main 2>/dev/null; then
                git -C "$main_sm_path" update-ref -d "$sync_ref"
            else
                echo "    warn: $sm — refs/heads/_update_sync exists and is not reachable from origin/main (not a stale sentinel); skipped to avoid clobbering it"
                skipped=$((skipped + 1))
                continue
            fi
        fi
        git -C "$main_sm_path" update-ref "$sync_ref" refs/remotes/origin/main

        if git -C "$peer_sm" fetch --quiet "$main_sm_path" \
               "$sync_ref:refs/heads/main" 2>/dev/null; then
            updated=$((updated + 1))
        else
            peer_head="$(git -C "$peer_sm" symbolic-ref --quiet HEAD 2>/dev/null || true)"
            if [[ "$peer_head" == "refs/heads/main" ]]; then
                echo "    warn: $sm has main checked out in $name — skipped"
            else
                echo "    warn: $sm main in $name has diverged from origin/main — skipped"
            fi
            skipped=$((skipped + 1))
        fi

        git -C "$main_sm_path" update-ref -d "$sync_ref" 2>/dev/null || true
    done < <(list_all_submodules)

    info "Updated $updated submodule main(s); $skipped skipped"
    cat <<EOF

Next: rebase the feature branches in $name onto the new main where needed.
  cd $wt_path
  git submodule foreach 'git rebase main'      # let conflicts halt the loop
EOF
}

cmd_list() {
    discover_root
    cd "$ROOT"
    git worktree list
}

# ---- status helpers -----------------------------------------------------
#
# status is read-only and offline by default (see docs/design/status.md).
# These helpers exist only for cmd_status — the _status_ prefix mirrors the
# _init_ wizard helpers — and lean on the shared is_clean/list_all_submodules.
# Each one returns 0 on every path: several are called via command
# substitution, where a non-zero return would trip `set -e`.

# _status_join SEP ELEM...  ->  "ELEM1<SEP>ELEM2..."
_status_join() {
    local sep="$1"; shift
    local out="" e
    for e in "$@"; do
        out="${out:+$out$sep}$e"
    done
    printf '%s' "$out"
}

# _status_ahead_behind DIR BASE TIP  ->  "↑A ↓B" (zero sides omitted; empty
# when either ref is missing or the two refs are identical).
_status_ahead_behind() {
    local dir="$1" base="$2" tip="$3" counts behind ahead out=""
    git -C "$dir" rev-parse --verify --quiet "$base" >/dev/null 2>&1 || return 0
    git -C "$dir" rev-parse --verify --quiet "$tip"  >/dev/null 2>&1 || return 0
    counts="$(git -C "$dir" rev-list --left-right --count "$base...$tip" 2>/dev/null)" || return 0
    # `--left-right --count` prints "<left> <right>": left = commits in BASE
    # not TIP (TIP is behind by that many), right = commits in TIP not BASE.
    read -r behind ahead <<<"$counts" || true
    [[ "${ahead:-0}"  != "0" ]] && out="↑$ahead"
    [[ "${behind:-0}" != "0" ]] && out="${out:+$out }↓$behind"
    printf '%s' "$out"
}

# _status_behind_origin DIR  ->  count of commits DIR's HEAD trails
# refs/remotes/origin/main by (empty when there is no such ref or it's not
# behind). Flags submodules that lag the published main — the "run update" case.
_status_behind_origin() {
    local dir="$1" n
    git -C "$dir" rev-parse --verify --quiet refs/remotes/origin/main >/dev/null 2>&1 || return 0
    n="$(git -C "$dir" rev-list --count "HEAD..refs/remotes/origin/main" 2>/dev/null)" || return 0
    [[ "$n" != "0" ]] && printf '%s' "$n"
    return 0
}

# _status_row WT LABEL NAME FETCH
# Prints one table row for worktree WT. LABEL is the WORKTREE-column text;
# NAME is the feature name used in the `update` hint; FETCH=true refreshes
# each touched submodule's origin/main first (the only network this does).
_status_row() {
    local wt="$1" label="$2" name="$3" fetch="$4"
    local branch dirty=false touched=() flags=() sm
    local submodules_col local_col remote_col ab

    branch="$(git -C "$wt" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
    [[ "$branch" == "HEAD" ]] && branch="(detached)"

    is_clean "$wt" || dirty=true

    # "Touched" = submodules carrying the worktree's feature branch. The main
    # worktree (branch == main) has no feature, so it lists none — otherwise
    # every submodule would show as "touched" just for carrying main.
    if [[ "$branch" != "main" && "$branch" != "(detached)" ]]; then
        while IFS= read -r sm; do
            [[ -n "$sm" ]] || continue
            [[ -e "$wt/$sm/.git" ]] || continue
            git -C "$wt/$sm" rev-parse --verify --quiet "refs/heads/$branch" >/dev/null 2>&1 || continue
            local mark="" behind
            if ! is_clean "$wt/$sm"; then mark="*"; dirty=true; fi
            touched+=("$sm$mark")
            if [[ "$fetch" == "true" ]]; then
                git -C "$wt/$sm" fetch --quiet origin main 2>/dev/null || true
            fi
            behind="$(_status_behind_origin "$wt/$sm")"
            if [[ -n "$behind" ]]; then
                flags+=("$sm behind origin/main → subgrove update $name")
            fi
        done < <(list_all_submodules 2>/dev/null)
    fi

    if [[ ${#touched[@]} -gt 0 ]]; then
        submodules_col="$(_status_join ", " "${touched[@]}")"
    else
        submodules_col="—"
    fi

    local_col="clean"; [[ "$dirty" == "true" ]] && local_col="dirty"
    ab="$(_status_ahead_behind "$wt" "refs/heads/main" "HEAD")"
    [[ -n "$ab" ]] && local_col="$local_col $ab"

    remote_col="$(_status_ahead_behind "$wt" "refs/remotes/origin/main" "HEAD")"
    [[ -z "$remote_col" ]] && remote_col="—"

    printf '%-12s %-16s %-24s %-12s %s\n' \
        "$label" "$branch" "$submodules_col" "$local_col" "$remote_col"
    local f
    for f in "${flags[@]}"; do
        printf '    ⚠ %s\n' "$f"
    done
}

cmd_status() {
    local fetch=false
    case "${1:-}" in
        --fetch) fetch=true ;;
    esac

    discover_root
    cd "$ROOT"

    # Parent origin/main is shared across all linked worktrees, so a single
    # fetch here refreshes it for every row; per-submodule origin/main lives
    # in isolated git dirs and is fetched inside _status_row. A fetch advances
    # only remote-tracking refs — no branch or working-tree mutation — so even
    # --fetch leaves the repo's actual state untouched; default status is
    # strictly offline and read-only.
    if [[ "$fetch" == "true" ]]; then
        git fetch --quiet origin main 2>/dev/null || true
    fi

    printf '%-12s %-16s %-24s %-12s %s\n' \
        "WORKTREE" "BRANCH" "SUBMODULES (touched)" "LOCAL" "REMOTE"
    _status_row "$ROOT" "(main)" "main" "$fetch"

    local any=false peer_wt name
    if [[ -d "$ROOT/$WORKTREES_DIR" ]]; then
        for peer_wt in "$ROOT/$WORKTREES_DIR"/*; do
            [[ -d "$peer_wt" ]] || continue
            any=true
            name="$(basename "$peer_wt")"
            _status_row "$peer_wt" "$name" "$name" "$fetch"
        done
    fi
    if [[ "$any" == "false" ]]; then
        echo
        echo "(no feature worktrees yet — create one with: subgrove new <name>)"
    fi
}

# >>> generated from lib/init.sh — edit there, then run ./build.sh >>>
# ---- init wizard --------------------------------------------------------
#
# Authored here; build.sh inlines this region into the single `subgrove`
# script. Edit THIS file, then run ./build.sh to sync. Never sourced at
# runtime — it is inlined, so it reuses err/info/list_all_submodules/
# discover_root and the WORKTREES_DIR/BUILD_*/BRANCH_PREFIX defaults from
# the parent script directly.

# _init_prompt VAR "Question" "default"
# Reads a line into VAR, falling back to the default on empty input. In
# non-interactive mode (--defaults or non-TTY stdin) it takes the default
# without prompting. printf -v is bash 3.1+, fine on macOS bash 3.2. The
# caller's $_init_noninteractive is visible here via bash dynamic scope.
_init_prompt() {
    local __q="$2" __def="$3" __ans
    if [[ "$_init_noninteractive" == "true" ]]; then
        printf -v "$1" '%s' "$__def"
        return
    fi
    printf '  %s [%s]: ' "$__q" "$__def" >&2
    IFS= read -r __ans || __ans=""
    [[ -z "$__ans" ]] && __ans="$__def"
    printf -v "$1" '%s' "$__ans"
}

# _init_emit_array NAME ELEMENTS...  -> prints `NAME=("e1" "e2")` (or `NAME=()`)
_init_emit_array() {
    local name="$1"; shift
    printf '%s=(' "$name"
    local first=true e
    for e in "$@"; do
        if [[ "$first" == "true" ]]; then first=false; else printf ' '; fi
        printf '"%s"' "$e"
    done
    printf ')\n'
}

# _init_split CSV_OR_WS  -> emits tokens space-separated (comma or whitespace
# input); "none"/empty yields nothing. Caller word-splits the result.
_init_split() {
    local v="$1"
    [[ "$v" == "none" || -z "$v" ]] && return 0
    printf '%s' "$v" | tr ',' ' '
}

cmd_init() {
    discover_root --allow-missing-config   # init writes the config, so absence is fine here
    cd "$ROOT"

    local _init_noninteractive=false
    case "${1:-}" in
        -y|--yes|--defaults) _init_noninteractive=true ;;
    esac
    [[ -t 0 ]] || _init_noninteractive=true   # piped/CI stdin: never block on a prompt

    local rc="$ROOT/.subgroverc"
    if [[ -f "$rc" ]]; then
        info "Reconfiguring — current values shown as [defaults]; Enter keeps them"
    else
        info "Setting up .subgroverc for this superproject"
    fi

    # 1. Worktree folder — repo-relative, gitignored (handled below); holds
    #    one subdirectory per feature worktree.
    _init_prompt WORKTREES_DIR "Worktree folder (relative to repo root)" "$WORKTREES_DIR"

    # 2. Branch prefix.
    _init_prompt BRANCH_PREFIX "Feature branch prefix" "$BRANCH_PREFIX"

    # 3. Build chain — offer the detected submodules by name.
    local detected=() sm
    while IFS= read -r sm; do
        [[ -n "$sm" ]] && detected+=("$sm")
    done < <(list_all_submodules 2>/dev/null)
    if [[ ${#detected[@]} -eq 0 ]]; then
        info "No submodules detected (.gitmodules absent or empty) — BUILD_CHAIN left empty"
        BUILD_CHAIN=()
    else
        info "Detected submodules: ${detected[*]}"
        local _chain_def="${BUILD_CHAIN[*]}" _chain_ans tok
        _init_prompt _chain_ans "Submodules to build on 'new' (space-separated, or 'none')" "$_chain_def"
        BUILD_CHAIN=()
        for tok in $(_init_split "$_chain_ans"); do
            BUILD_CHAIN+=("$tok")
        done
    fi

    # 4. Build command — only meaningful when there's a chain to build.
    if [[ ${#BUILD_CHAIN[@]} -gt 0 ]]; then
        _init_prompt BUILD_CMD "Build command run inside each BUILD_CHAIN module" "$BUILD_CMD"
    fi

    # 5. Files/dirs copied into each new worktree.
    local _copy_def="${COPY_TO_NEW_WORKTREE[*]}" _copy_ans citem
    _init_prompt _copy_ans "Files/dirs copied into each new worktree (space-separated, or 'none')" "$_copy_def"
    COPY_TO_NEW_WORKTREE=()
    for citem in $(_init_split "$_copy_ans"); do
        COPY_TO_NEW_WORKTREE+=("$citem")
    done

    # Write .subgroverc, backing up any existing one first.
    if [[ -f "$rc" ]]; then
        cp "$rc" "$rc.bak"
        info "Backed up existing .subgroverc to .subgroverc.bak"
    fi
    {
        echo "# subgrove configuration — generated by 'subgrove init'."
        echo "# Sourced by subgrove from the superproject root. See"
        echo "# .subgroverc.example for the full schema and notes."
        echo
        echo "# Folder (repo-relative) that holds per-feature worktrees; gitignored."
        printf 'WORKTREES_DIR="%s"\n' "$WORKTREES_DIR"
        echo
        echo "# Ordered submodule paths to build during 'new' (empty = no auto-build)."
        _init_emit_array BUILD_CHAIN "${BUILD_CHAIN[@]}"
        echo
        echo "# Shell command run inside each BUILD_CHAIN module."
        printf 'BUILD_CMD="%s"\n' "$BUILD_CMD"
        echo
        echo "# Files/dirs under the main worktree copied into each new worktree."
        _init_emit_array COPY_TO_NEW_WORKTREE "${COPY_TO_NEW_WORKTREE[@]}"
        echo
        echo "# Feature branch prefix (include the trailing separator, e.g. \"feat/\")."
        printf 'BRANCH_PREFIX="%s"\n' "$BRANCH_PREFIX"
    } > "$rc"
    info "Wrote $rc"

    # Ensure .worktree/ is gitignored AND present on disk: subgrove's
    # `git check-ignore -q .worktree` matches the trailing-slash pattern only
    # when the directory actually exists.
    if ! git check-ignore -q "$WORKTREES_DIR" 2>/dev/null; then
        local _gi_ans
        if [[ "$_init_noninteractive" == "true" ]]; then
            _gi_ans="y"
        else
            printf '  %s/ must be gitignored for subgrove to run. Add it now? [Y/n]: ' "$WORKTREES_DIR" >&2
            IFS= read -r _gi_ans || _gi_ans="y"
        fi
        case "$_gi_ans" in
            ""|y|Y|yes|Yes)
                printf '%s/\n' "$WORKTREES_DIR" >> "$ROOT/.gitignore"
                git add .gitignore 2>/dev/null || true
                info "Added $WORKTREES_DIR/ to .gitignore (staged)"
                ;;
            *)
                info "Left .gitignore alone — subgrove refuses to run until $WORKTREES_DIR/ is ignored"
                ;;
        esac
    fi
    mkdir -p "$ROOT/$WORKTREES_DIR"

    cat <<EOF

subgrove is configured for $ROOT
  Config: $rc
  Next:   subgrove new <feature>
EOF
}
