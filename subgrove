main() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true
    case "$subcmd" in
        new)                cmd_new "$@" ;;
        init)               cmd_init "$@" ;;
        merge)              cmd_merge "$@" ;;
        remove|rm)          cmd_remove "$@" ;;
        update)             cmd_update "$@" ;;
        status)             cmd_status "$@" ;;
        list|ls)            cmd_list ;;
        help|-h|--help)     usage ;;
        version|--version)  echo "subgrove $VERSION" ;;
        *)                  usage; exit 1 ;;
    esac
}

main "$@"
