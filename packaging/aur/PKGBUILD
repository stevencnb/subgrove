# Maintainer: Steven Chang <https://github.com/stevencnb>
#
# AUR PKGBUILD for subgrove. `pkgver` tracks VERSION in `subgrove`, and the
# sha256sum is the v$pkgver release tarball's checksum — regenerate both when
# bumping (`makepkg -g` recomputes the sum). subgrove is a single
# self-contained shell script; the release tarball must be built (`./build.sh`)
# and in sync before tagging so it carries the inlined `init` wizard.
pkgname=subgrove
pkgver=0.2.0
pkgrel=1
pkgdesc="Parallel feature worktrees for a git superproject with submodules"
arch=('any')
url="https://github.com/stevencnb/subgrove"
license=('MIT')
depends=('git' 'bash')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('10faf3480c8dddbb628efac9459843012fdc1024f93ab40029637308c4f693c1')

package() {
    cd "$srcdir/$pkgname-$pkgver"
    install -Dm755 subgrove "$pkgdir/usr/bin/subgrove"
    install -Dm644 completions/subgrove.bash "$pkgdir/usr/share/bash-completion/completions/subgrove"
    install -Dm644 completions/_subgrove "$pkgdir/usr/share/zsh/site-functions/_subgrove"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
